---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Rahalsa Abi Umara — ML Enthusiast, Web Developer, Data Analyst",
  description = "Personal portfolio of Rahalsa Abi Umara. Machine Learning Enthusiast, Web Developer, and Data Analyst building intelligent solutions."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="favicon.ico" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Rahalsa Abi Umara" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
