---

---

<section class="section achievements" id="achievements">
  <div class="container">
    <div class="section-header">
      <div class="section-label reveal">RECOGNITION</div>
      <h2 class="display-lg reveal reveal-delay-1">ACHIEVEMENTS</h2>
      <p class="section-subtitle reveal reveal-delay-2">
        A consistent track record of excellence in national competitions and academic recognition.
      </p>
    </div>

    <div class="achievements-grid">
      <!-- Achievement 1 -->
      <div class="achievement-card reveal">
        <div class="achievement-image">
          <img src="/achievement-1.png" alt="Mahasiswa Berprestasi UNY 2026" loading="lazy" />
          <div class="achievement-badge achievement-badge--gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            <span>OUTSTANDING</span>
          </div>
        </div>
        <div class="achievement-body">
          <div class="achievement-year">2026</div>
          <h3 class="achievement-title">Mahasiswa Berprestasi Universitas Negeri Yogyakarta</h3>
          <div class="achievement-org">Bidang Penalaran — UNY</div>
          <p class="achievement-desc">
            Awards presented by the Rector to outstanding students in 2026, held at UNY on National Education Day.
          </p>
          <div class="achievement-stripe">
            <span></span><span></span><span></span>
          </div>
        </div>
      </div>

      <!-- Achievement 2 -->
      <div class="achievement-card reveal reveal-delay-1">
        <div class="achievement-image">
          <img src="/achievement-2.png" alt="2nd Place Software Development Unity 2026" loading="lazy" />
          <div class="achievement-badge achievement-badge--silver">
            <span>2<sup>ND</sup> PLACE</span>
          </div>
        </div>
        <div class="achievement-body">
          <div class="achievement-year">2026</div>
          <h3 class="achievement-title">2nd Place Software Development Unity Competition</h3>
          <div class="achievement-org">UNY — National Level</div>
          <p class="achievement-desc">
            A national software development competition organized by Yogyakarta State University.
          </p>
          <div class="achievement-stripe">
            <span></span><span></span><span></span>
          </div>
        </div>
      </div>

      <!-- Achievement 3 -->
      <div class="achievement-card reveal reveal-delay-2">
        <div class="achievement-image">
          <img src="/achievement-3.png" alt="1st Place National Essay SAGA UNNES 2025" loading="lazy" />
          <div class="achievement-badge achievement-badge--gold">
            <span>1<sup>ST</sup> PLACE</span>
          </div>
        </div>
        <div class="achievement-body">
          <div class="achievement-year">2025</div>
          <h3 class="achievement-title">1st Place National Essay Competition SAGA</h3>
          <div class="achievement-org">UNNES — National Level</div>
          <p class="achievement-desc">
            A national essay contest organized by Semarang State University.
          </p>
          <div class="achievement-stripe">
            <span></span><span></span><span></span>
          </div>
        </div>
      </div>

      <!-- Achievement 4 -->
      <div class="achievement-card reveal reveal-delay-3">
        <div class="achievement-image">
          <img src="/achievement-4.png" alt="1st Place Software Development Unity 2025" loading="lazy" />
          <div class="achievement-badge achievement-badge--gold">
            <span>1<sup>ST</sup> PLACE</span>
          </div>
        </div>
        <div class="achievement-body">
          <div class="achievement-year">2025</div>
          <h3 class="achievement-title">1st Place Software Development Unity Competition</h3>
          <div class="achievement-org">UNY — National Level</div>
          <p class="achievement-desc">
            A national software development competition organized by Yogyakarta State University.
          </p>
          <div class="achievement-stripe">
            <span></span><span></span><span></span>
          </div>
        </div>
      </div>

      <!-- Achievement 5 -->
      <div class="achievement-card reveal reveal-delay-4">
        <div class="achievement-image">
          <img src="/achievement-5.png" alt="2nd Place Software Development IDTC ITENAS 2025" loading="lazy" />
          <div class="achievement-badge achievement-badge--silver">
            <span>2<sup>ND</sup> PLACE</span>
          </div>
        </div>
        <div class="achievement-body">
          <div class="achievement-year">2025</div>
          <h3 class="achievement-title">2nd Place Software Development IDTC</h3>
          <div class="achievement-org">ITENAS Bandung — National Level</div>
          <p class="achievement-desc">
            A national software development competition organized by the Bandung Institute of National Technology.
          </p>
          <div class="achievement-stripe">
            <span></span><span></span><span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
