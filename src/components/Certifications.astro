---

---

<section class="section certifications" id="certifications">
  <div class="container">
    <div class="section-header">
      <div class="section-label reveal">PROFESSIONAL DEVELOPMENT</div>
      <h2 class="display-lg reveal reveal-delay-1">CERTIFICATIONS</h2>
      <p class="section-subtitle reveal reveal-delay-2">
        Has completed <strong style="color: var(--color-on-dark); font-weight: 700;">40+</strong> training certifications from various international platforms and institutions.
      </p>
    </div>

    <!-- Certificate Image Carousel (infinite looping) -->
    <div class="cert-carousel reveal reveal-delay-3">
      <div class="cert-carousel-track" id="cert-carousel-track">
        <!-- Original set -->
        <div class="cert-carousel-slide">
          <img src="/cert-1.png" alt="Certificate 1" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-2.png" alt="Certificate 2" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-3.png" alt="Certificate 3" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-4.png" alt="Certificate 4" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-5.png" alt="Certificate 5" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-6.png" alt="Certificate 6" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-7.png" alt="Certificate 7" loading="lazy" />
        </div>
        <!-- Duplicate set for seamless loop -->
        <div class="cert-carousel-slide">
          <img src="/cert-2.png" alt="Certificate 2" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-3.png" alt="Certificate 3" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-1.png" alt="Certificate 1" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-4.png" alt="Certificate 4" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-5.png" alt="Certificate 5" loading="lazy" />
        </div>
        <div class="cert-carousel-slide">
          <img src="/cert-6.png" alt="Certificate 6" loading="lazy" />
        </div>
      </div>
      <!-- Gradient overlays for seamless edge fading -->
      <div class="cert-carousel-fade cert-carousel-fade--left"></div>
      <div class="cert-carousel-fade cert-carousel-fade--right"></div>
    </div>

    <div class="reveal" style="display: flex; justify-content: center; margin-top: 3rem;">
      <a href="https://drive.google.com/drive/folders/14EfrP83DThvh2NkrK7xYMgxZ6UEm40HT?usp=sharing" target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.75rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
        VIEW ALL CERTIFICATES
      </a>
    </div>
  </div>
</section>
