---

---

<section class="section education" id="education" style="background: var(--color-surface-soft);">
  <div class="container">
    <div class="about-grid">
      <!-- Image Side -->
      <div class="about-image-wrapper reveal">
        <div class="about-image">
          <img src="/education.png" alt="Education" loading="lazy" />
          <div class="about-image-accent">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="about-image-border"></div>
      </div>

      <!-- Text Side -->
      <div class="about-text">
        <div class="section-label reveal">ACADEMIC BACKGROUND</div>
        <h2 class="display-lg reveal reveal-delay-1">EDUCATION</h2>

        <div class="reveal reveal-delay-2" style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-hairline);">
          <img src="/logo-univ.png" alt="Yogyakarta State University Logo" style="width: 80px; height: 80px; object-fit: contain;" />
          <div>
            <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem; font-weight: 700; color: var(--color-on-dark); line-height: 1.2;">Yogyakarta State University</h3>
            <p style="color: var(--color-m-blue-dark); font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0;">Bachelor of Information Technology</p>
          </div>
        </div>

        <p class="about-description reveal reveal-delay-3">
          A Fresh Graduate of the Information Technology program at Yogyakarta State University (2026) with a cumulative grade point average (GPA) of <strong style="color: var(--color-on-dark); font-weight: 600;">3.75</strong> and focused studies on <strong style="color: var(--color-on-dark); font-weight: 400;">Machine Learning</strong>, <strong style="color: var(--color-on-dark); font-weight: 400;">Data Analysis</strong>, and <strong style="color: var(--color-on-dark); font-weight: 400;">Software Engineering</strong>. Actively developing skills through various academic and independent projects. Actively participates in student organization activities and various competitions.
        </p>
      </div>
    </div>
  </div>
</section>
