---

<section class="section about" id="about">
  <div class="container">
    <div class="about-grid">
      <!-- Image Side -->
      <div class="about-image-wrapper reveal">
        <div class="about-image">
          <img src="/profile.png" alt="Rahalsa Abi Umara" loading="lazy" />
          <div class="about-image-accent">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
        <div class="about-image-border"></div>
      </div>

      <!-- Text Side -->
      <div class="about-text">
        <div class="section-label reveal">ABOUT ME</div>
        <h2 class="display-lg reveal reveal-delay-1">WHO I AM</h2>

        <p class="about-description reveal reveal-delay-2">
          A 2022 Information Technology student at Yogyakarta State University with a Cumulative Grade Point Average
(CGPA) of 3.75. Possesses in-depth expertise in <strong style="color: var(--color-on-dark); font-weight: 400;">Machine Learning</strong>,
          <strong style="color: var(--color-on-dark); font-weight: 400;">Web Development</strong>, and
          <strong style="color: var(--color-on-dark); font-weight: 400;">Data Analytics</strong>.
          Experienced in various real-world projects ranging from the development of internal company dashboards to systems based on artificial intelligence and IoT. Active in national competitions with a consistent track record of achievements, and has completed over 41 training certifications from leading international institutions.
        </p>

        <div class="about-stats reveal reveal-delay-3">
          <div class="stat-item">
            <div class="stat-number">5<span class="stat-accent">+</span></div>
            <div class="stat-label">PROJECTS</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">10<span class="stat-accent">+</span></div>
            <div class="stat-label">TECHNOLOGIES</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">3<span class="stat-accent">+</span></div>
            <div class="stat-label">FIELDS</div>
          </div>
        </div>

        <div class="tech-stack reveal reveal-delay-4">
          <div class="tech-stack-label">TECH STACK</div>
          <div class="tech-stack-grid">
            <span class="tech-item">Python</span>
            <span class="tech-item">TensorFlow</span>
            <span class="tech-item">PyTorch</span>
            <span class="tech-item">Scikit-learn</span>
            <span class="tech-item">React</span>
            <span class="tech-item">Next.js</span>
            <span class="tech-item">JavaScript</span>
            <span class="tech-item">SQL</span>
            <span class="tech-item">Pandas</span>
            <span class="tech-item">Tableau</span>
            <span class="tech-item">Streamlit</span>
            <span class="tech-item">PowerBI</span>
            <span class="tech-item">Node.js</span>
            <span class="tech-item">Git</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
